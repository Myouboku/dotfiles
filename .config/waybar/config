{
    "layer": "top",
    "height": 30,
    "spacing": 8,
    "margin-top": 14,
    "margin-left": 14,
    "margin-right": 14,
    "modules-left": [
        "hyprland/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [
        "hyprland/window",
        "mpris"
    ],
    "modules-right": [
        "pulseaudio",
        "clock"
    ],
    "wlr/taskbar": {
        "icon-size": 12,
        "on-click": "activate",
        "on-click-right": "close"
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} {title}",
        "player-icons": {
            "default": "▶"
        },
        "status-icons": {
            "paused": "⏸"
        }
    },
    "pulseaudio": {
        "format": "Vol : {volume}% | Mic : {format_source}",
        "on-click": "pavucontrol --tab=3"
    },
    "clock": {
        "timezone": "Europe/Paris",
        "format": "{:%H:%M | %d-%m-%y}"
    }
}