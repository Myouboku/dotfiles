{
    "layer": "top",
    "height": 30,
    "spacing": 8,
    "margin-top": 14,
    "margin-left": 14,
    "margin-right": 14,
    "modules-left": [
        "hyprland/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [
        // TODO: Add a module to display current music (check MPRIS)
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "clock"
    ],
    "wlr/taskbar": {
        "icon-size": 12,
        "on-click": "activate",
        "on-click-right": "close"
    },
    "pulseaudio": {
        "format": "Vol : {volume}% | Mic : {format_source}",
        "on-click": "pavucontrol --tab=3"
    },
    "clock": {
        "timezone": "Europe/Paris",
        "format": "{:%H:%M | %d-%m-%y}"
    }
}