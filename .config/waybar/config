{
    "layer": "top",
    "height": 30,
    "spacing": 8,
    "margin-top": 14,
    "margin-left": 14,
    "margin-right": 14,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "clock"
    ],
    "pulseaudio": {
        "format": "Vol : {volume}% | Mic : {format_source}",
        "on-click": "pavucontrol --tab=3"
    },
    "clock": {
        "timezone": "Europe/Paris",
        "format": "{:%H:%M | %d-%m-%y}"
    }
}